{
  "name": "remotion-video-editor",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./scripts/next-wasm-preload.js ./node_modules/next/dist/bin/next dev -H 0.0.0.0",
    "dev:all": "bash ./scripts/dev-all.sh",
    "dev:restart": "bash ./scripts/restart-all.sh",
    "build": "node -r ./scripts/next-wasm-preload.js ./node_modules/next/dist/bin/next build",
    "start": "node -r ./scripts/next-wasm-preload.js ./node_modules/next/dist/bin/next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "scheduler": "ts-node --esm tasks/scheduler.ts",
    "scheduler:watch": "nodemon --watch tasks/scheduler.ts --exec \"ts-node --esm tasks/scheduler.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest __tests__/unit",
    "test:integration": "jest __tests__/integration",
    "test:e2e": "jest __tests__/e2e"
  },
  "dependencies": {
    "@next/swc-darwin-arm64": "^14.2.18",
    "@next/swc-wasm-nodejs": "^14.2.18",
    "@remotion/bundler": "4.0.434",
    "@remotion/cli": "4.0.434",
    "@remotion/gif": "4.0.434",
    "@remotion/google-fonts": "4.0.434",
    "@remotion/player": "4.0.434",
    "@remotion/renderer": "^4.0.434",
    "@remotion/shapes": "4.0.434",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "clsx": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.434",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "14.2.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.49",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "undici": "^7.22.0"
  }
}
